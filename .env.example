# 环境变量配置（复制为 .env 使用）
APP_NAME=FastAPI Demo
DEBUG=false
LOG_LEVEL=INFO
LOG_DIR=logs

# 数据库（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_demo

# JWT
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gunicorn
WORKERS=4
BIND=0.0.0.0:8000
